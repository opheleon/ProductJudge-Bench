# Copy to .env and fill in the key(s) for the provider(s) you want to run.
# Only `sdbench run` needs keys — grading and reporting make zero LLM calls.
#
# sdbench loads .env from the current directory automatically (existing
# environment variables win). Model ids are litellm ids, e.g.:
#   sdbench run --model anthropic/claude-sonnet-5
#   sdbench run --model openai/gpt-5.6
#   sdbench run --model gemini/gemini-2.5-pro

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
